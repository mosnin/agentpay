# ----------------------------------------------------------------------------
# Bids — environment variables
# Copy to `.env` and fill in. The MVP only requires DATABASE_URL.
# ----------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
# Local dev example (matches docker-compose / a local Postgres):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bids?schema=public"

# Public base URL of the app. Used as the metadataBase for absolute URLs in
# OpenGraph/Twitter cards, the sitemap, robots.txt, the web manifest, and
# canonical links (and in the developer docs examples). Set this to your
# deployed origin in production so shared/SEO links resolve correctly.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# Optional / future integrations — all MOCKED in the MVP.
# Leave blank to use the built-in mock adapters.
# ----------------------------------------------------------------------------

# Clerk auth (integrated). Set both keys to enable real sign-in/sign-up with
# protected routes and JIT user provisioning; leave unset to run keyless as
# the seeded demo operator (local dev / CI need no Clerk account).
# Keys: https://dashboard.clerk.com -> API keys
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# Optional Clerk route overrides (defaults shown):
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk webhook sync (recommended in production). Add an endpoint in the
# Clerk Dashboard -> Webhooks pointing at /api/webhooks/clerk with the
# user.updated and user.deleted events, then paste its signing secret here.
# Keeps names/emails in sync and scrubs PII when an account is deleted.
# CLERK_WEBHOOK_SIGNING_SECRET=

# Admin bootstrap. Comma-separated emails that receive the admin role
# automatically at sign-in (promotion only — never demotes anyone).
# ADMIN_EMAILS=you@yourdomain.com

# Rate limiting (recommended in production). With these set, limits are
# enforced globally via Upstash Redis; unset, an in-memory fallback applies
# per serverless instance only. Free tier: https://upstash.com
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Agent verification program (optional). When set, the endpoint health check
# signs its challenge (HMAC) and requires the agent to prove possession of the
# shared secret; unset, health checks still run but are reachability-only and
# say so honestly. See lib/verification.ts.
# VERIFICATION_SECRET=

# Scheduled re-verification (required to enable /api/cron/verify). The cron
# route returns 503 until this is set, so it never runs unauthenticated. Point
# a Vercel Cron (or any scheduler) at /api/cron/verify with this as a bearer.
# CRON_SECRET=

# Privacy-friendly analytics (optional, cookieless). Unset = every track()
# call no-ops with zero network requests (no fake events). Set the endpoint to
# a collector (Umami/Plausible-style) to record the four funnel events:
# signup started, onboarding completed, first task created, first task completed.
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=
# NEXT_PUBLIC_ANALYTICS_WEBSITE_ID=

# x402 payments (optional). If unset, lib/payments/x402Adapter.ts runs in mock mode.
# X402_API_KEY=
# X402_FACILITATOR_URL=

# A2A / MCP interop (optional). If unset, lib/interop/* run with local mock data.
# A2A_REGISTRY_URL=
# MCP_GATEWAY_URL=
