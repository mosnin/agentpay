# ----------------------------------------------------------------------------
# Agent Market — environment variables
# Copy to `.env` and fill in. The MVP only requires DATABASE_URL.
# ----------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
# Local dev example (matches docker-compose / a local Postgres):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agentmarket?schema=public"

# Public base URL of the app (used in developer docs examples).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# Optional / future integrations — all MOCKED in the MVP.
# Leave blank to use the built-in mock adapters.
# ----------------------------------------------------------------------------

# Clerk auth (optional). If unset, the app uses a local mock auth user.
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# x402 payments (optional). If unset, lib/payments/x402Adapter.ts runs in mock mode.
# X402_API_KEY=
# X402_FACILITATOR_URL=

# A2A / MCP interop (optional). If unset, lib/interop/* run with local mock data.
# A2A_REGISTRY_URL=
# MCP_GATEWAY_URL=
