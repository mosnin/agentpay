// Agent Market — Prisma schema
// PostgreSQL. Models cover the full marketplace lifecycle:
// discover -> hire -> contract -> execute -> validate -> complete -> pay -> review -> reputation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AgentStatus {
  draft
  active
  paused
  suspended
}

enum PricingModel {
  per_task
  subscription
  bounty
  hourly
}

enum TaskStatus {
  draft
  pending
  accepted
  running
  submitted
  validating
  completed
  disputed
  cancelled
}

enum TaskVisibility {
  public
  private
  unlisted
}

enum PaymentMode {
  mock_escrow
  pay_per_task
  subscription_access
  bounty
}

enum PaymentStatus {
  pending
  escrowed
  released
  refunded
  failed
}

enum ValidationStatus {
  pending
  passed
  failed
}

enum DisputeStatus {
  open
  reviewing
  resolved
  rejected
}

enum ReputationEventType {
  task_completed
  positive_review
  negative_review
  dispute_opened
  dispute_resolved
  verification
  schema_compliance
  sla_met
  sla_missed
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  role      String   @default("operator")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  agents   Agent[]   @relation("AgentOwner")
  tasks    Task[]    @relation("TaskBuyer")
  reviews  Review[]
  disputes Dispute[] @relation("DisputeOpener")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users  User[]
  agents Agent[]
}

model Agent {
  id                    String       @id @default(cuid())
  name                  String
  slug                  String       @unique
  shortDescription      String
  longDescription       String
  category              String
  status                AgentStatus  @default(active)
  verified              Boolean      @default(false)
  endpointUrl           String?
  mcpServerUrl          String?
  pricingModel          PricingModel @default(per_task)
  startingPrice         Float        @default(0)
  currency              String       @default("USD")
  averageRating         Float        @default(0)
  reputationScore       Int          @default(50)
  completionRate        Float        @default(0)
  averageLatencyMinutes Int          @default(0)
  schemaComplianceScore Float        @default(0)
  disputeRate           Float        @default(0)
  totalTasksCompleted   Int          @default(0)
  inputSchema           Json?
  outputSchema          Json?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  ownerId        String
  owner          User          @relation("AgentOwner", fields: [ownerId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  capabilities     AgentCapability[]
  tasks            Task[]            @relation("TaskSellerAgent")
  reviews          Review[]
  reputationEvents ReputationEvent[]

  @@index([category])
  @@index([reputationScore])
  @@index([verified])
}

model Capability {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agents AgentCapability[]
}

model AgentCapability {
  id           String     @id @default(cuid())
  agentId      String
  capabilityId String
  agent        Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  capability   Capability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@unique([agentId, capabilityId])
  @@index([agentId])
  @@index([capabilityId])
}

model Task {
  id         String         @id @default(cuid())
  title      String
  objective  String
  category   String
  status     TaskStatus     @default(draft)
  visibility TaskVisibility @default(public)
  budget     Float          @default(0)
  currency   String         @default("USD")
  deadline   DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  buyerId       String
  buyer         User    @relation("TaskBuyer", fields: [buyerId], references: [id])
  sellerAgentId String?
  sellerAgent   Agent?  @relation("TaskSellerAgent", fields: [sellerAgentId], references: [id])

  contract         TaskContract?
  artifacts        Artifact[]
  payment          Payment?
  reviews          Review[]
  reputationEvents ReputationEvent[]
  disputes         Dispute[]

  @@index([status])
  @@index([category])
  @@index([buyerId])
  @@index([sellerAgentId])
}

model TaskContract {
  id              String      @id @default(cuid())
  taskId          String      @unique
  task            Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  inputPayload    Json?
  outputSchema    Json?
  validationRules Json?
  paymentMode     PaymentMode @default(mock_escrow)
  successCriteria String?
  contractHash    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Artifact {
  id               String           @id @default(cuid())
  taskId           String
  task             Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title            String
  type             String           @default("json")
  url              String?
  content          String?
  validationStatus ValidationStatus @default(pending)
  validationScore  Int?
  validationNotes  String[]         @default([])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([taskId])
}

model Payment {
  id              String        @id @default(cuid())
  taskId          String        @unique
  task            Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  amount          Float
  currency        String        @default("USD")
  status          PaymentStatus @default(pending)
  mode            PaymentMode   @default(mock_escrow)
  provider        String        @default("x402_mock")
  transactionHash String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([taskId])
}

model ReputationEvent {
  id         String              @id @default(cuid())
  agentId    String
  agent      Agent               @relation(fields: [agentId], references: [id], onDelete: Cascade)
  taskId     String?
  task       Task?               @relation(fields: [taskId], references: [id])
  type       ReputationEventType
  scoreDelta Int                 @default(0)
  reason     String?
  createdAt  DateTime            @default(now())

  @@index([agentId])
}

model Dispute {
  id         String        @id @default(cuid())
  taskId     String
  task       Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  openedById String
  openedBy   User          @relation("DisputeOpener", fields: [openedById], references: [id])
  reason     String
  status     DisputeStatus @default(open)
  resolution String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([status])
}
